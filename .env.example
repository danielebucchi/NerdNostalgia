# NerdNostalgia — variabili d'ambiente
# Copia in .env e personalizza. .env non e' versionato.

# ---------- Generic ----------
TZ=Europe/Rome
APP_TIMEZONE=Europe/Rome

# ---------- Backend ----------
# Disabilita lo scheduler APScheduler (utile in dev se non vuoi log Vinted)
# DISABLE_SCHEDULER=1

# JWT signing key — CAMBIALA in produzione (almeno 64 char random)
JWT_SECRET_KEY=dev-secret-change-me

# ---------- SMTP (Gmail App Password compatibile) ----------
EMAIL_ENABLED=0
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO_ADMIN=nerdnostalgiaita@gmail.com

# ---------- Frontend (build-time, baked into Next.js bundle) ----------
NEXT_PUBLIC_API_BASE_URL=http://localhost:7373
NEXT_PUBLIC_SITE_URL=http://localhost:3737
# Handle paypal.me per il bottone Donazione + (se abilitati) PayPal checkout.
# Se vuoto, i bottoni PayPal sono nascosti.
NEXT_PUBLIC_PAYPAL_ME=
# Master switch per la pipeline d'acquisto (carrello, CTA "Paga con PayPal"
# sull'articolo, /carrello, /admin/ordini). False = nasconde tutto.
# La Donazione (FAB in basso a destra) resta sempre visibile se PAYPAL_ME
# e' configurato, indipendentemente da questo flag.
NEXT_PUBLIC_PAYMENTS_ENABLED=false

# ---------- Backup (opzionali) ----------
# Se BACKUP_S3_BUCKET e' settato, il job giornaliero carica anche su S3/R2
# BACKUP_S3_BUCKET=
# BACKUP_S3_ENDPOINT=  # solo per R2/MinIO; vuoto per AWS
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=auto
