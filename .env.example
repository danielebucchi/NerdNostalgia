# Environment variables per NerdNostalgia
# Copia questo file come .env e inserisci i tuoi valori

# eBay API Credentials
# Ottieni le tue credenziali su: https://developer.ebay.com/
EBAY_APP_ID=your_app_id_here
EBAY_DEV_ID=your_dev_id_here
EBAY_CERT_ID=your_cert_id_here
EBAY_TOKEN=your_user_token_here

# Amazon API Credentials (future)
AMAZON_MARKETPLACE_ID=
AMAZON_SELLER_ID=
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
