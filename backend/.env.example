# Database Configuration
# PostgreSQL (production):
DATABASE_URL=postgresql://user:password@localhost:5432/nerdnostalgia

# SQLite (development):
# DATABASE_URL=sqlite:///./nerdnostalgia.db

# JWT — generare in produzione con: openssl rand -hex 32
JWT_SECRET_KEY=dev-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Storage uploads
APP_TMP_DIR=/tmp/nerdnostalgia
BASE_URL=http://localhost:7373
MAX_UPLOAD_SIZE_MB=5
